# Environment contract for ebook-reader (single file, repo root).
# Copy to `.env` and fill EVERY variable — both apps validate on startup and
# refuse to run if any of these are missing or malformed.

# --- Web (Vite) -----------------------------------------------------------
# Must be prefixed VITE_ to be exposed to the client. Loaded from this root
# file via Vite's envDir (see apps/web/vite.config.ts).
VITE_API_URL=http://localhost:3001

# --- API (Fastify) --------------------------------------------------------
PORT=3001
HOST=0.0.0.0

# Shared platform password (brief 09). REQUIRED — the API will not start
# without it and the web app gates every route behind it. Use a strong value.
APP_PASSWORD=change-me

MAX_UPLOAD_MB=50
CONVERT_TIMEOUT_MS=60000
