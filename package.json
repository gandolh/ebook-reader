{
  "name": "ebook-reader",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w @ebook-reader/web\" \"npm run dev -w @ebook-reader/api\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "9.2.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
